      - rtl

parameters:
  LSB:
    datatype: int
    paramtype: vlogparam
  DATA_WIDTH:
    datatype: int
    paramtype: vlogparam

filesets:
  rtl:
    file_type: systemVerilogSource
    files:
      - edge_detection/hdl/edge_detection.sv


provider :
