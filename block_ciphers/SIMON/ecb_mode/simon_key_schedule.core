CAPI=2:

name : ::simon_key_schedule:0
description : simon key_schedule cte 

targets:
  default:
    filesets: 
      - rtl

  sim : 
    flow : sim
    flow_options :
      tool : verilator 
      verilator_options : [-Wno-WIDTHEXPAND -Wno-WIDTHTRUNC -Wno-SELRANGE]
      cocotb_module : simon_key_schedule_test
      timescale : 1ns/1ns
      vcs_options : [-timescale=1ns/1ns]
    filesets : [rtl ,cocotb]  
    toplevel : key_schedule
    parameters :
      - N=16
      - M=4
      - T=32

parameters :
  N :
    datatype : int
    paramtype : vlogparam
  M :
    datatype : int
    paramtype : vlogparam
  T :
    datatype : int
    paramtype : vlogparam

filesets:
  cocotb :
    files :
      - ecb_mode/cocotb/simon_key_schedule_test.py : {file_type : user, copyto : .}
      - ecb_mode/python/simon.py : {file_type : user, copyto : .}
    depend :
      - vlog_tb_utils


  rtl:
    file_type: systemVerilogSource
    files: 
      - ecb_mode/hdl/key_schedule.sv      
    depend:
      - counter
      - register

provider:
    name: github
    user: germancq
    repo: simon_block_cipher
    version: main







