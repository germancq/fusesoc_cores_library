CAPI=2:

name : ::clefia_key_schedule:0
description : clefia key_schedule function

targets:
  default:
    filesets: 
      - rtl

  sim : 
    flow : sim
    flow_options :
      tool : verilator 
      verilator_options : [-Wno-WIDTHEXPAND -Wno-WIDTHTRUNC -Wno-SELRANGE]
      cocotb_module : key_schedule_test
      timescale : 1ns/1ns
      vcs_options : [-timescale=1ns/1ns]
    filesets : [rtl ,cocotb]  
    toplevel : key_schedule
    parameters :
      - KEY_LEN=128

parameters :
  KEY_LEN :
    datatype : int
    paramtype : vlogparam

filesets:
  cocotb :
    files :
      - ecb_mode/cocotb/key_schedule_test.py : {file_type : user, copyto : .}
      - ecb_mode/python/clefia.py : {file_type : user, copyto : .}
      - ecb_mode/python/galois_arithmetic.py : {file_type : user, copyto : .}
    depend :
      - vlog_tb_utils


  rtl:
    file_type: systemVerilogSource
    files: 
      - ecb_mode/hdl/key_schedule.sv      
    depend:
      - clefia_gfn
      - clefia_gen_con
      - counter
      - register

provider:
    name: github
    user: germancq
    repo: clefia_block_cipher
    version: main






